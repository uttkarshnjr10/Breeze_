{
    "name": "@breeze/api-gateway",
    "version": "0.1.0",
    "private": true,
    "description": "Breeze API Gateway — Apollo Server 4 + GraphQL + Express",
    "main": "./dist/server.js",
    "scripts": {
        "build": "tsc -b",
        "dev": "tsx watch src/server.ts",
        "start": "node dist/server.js",
