        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@breeze/shared": "*",
        "@apollo/server": "^4.10.0",
        "graphql": "^16.8.1",
        "graphql-tag": "^2.12.6",
        "@graphql-tools/utils": "^10.1.0",
        "@graphql-tools/schema": "^10.0.3",
        "express": "^4.18.3",
        "helmet": "^7.1.0",
        "cors": "^2.8.5",
        "compression": "^1.7.4",
        "ioredis": "^5.3.2",
        "@grpc/grpc-js": "^1.10.0",
        "@grpc/proto-loader": "^0.7.10",
        "kafkajs": "^2.2.4",
        "zod": "^3.22.4",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "typescript": "^5.4.0",
        "tsx": "^4.7.0",
        "@types/express": "^4.17.21",
        "@types/cors": "^2.8.17",
        "@types/compression": "^1.7.5",
        "@types/uuid": "^9.0.8",
        "vitest": "^1.3.0"
