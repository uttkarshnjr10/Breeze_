{
    "name": "@breeze/auth-service",
    "version": "0.1.0",
    "private": true,
    "description": "Breeze Auth Service — authentication, authorization, and user profiles",
    "main": "./dist/index.js",
    "scripts": {
        "build": "tsc -b",
        "dev": "tsx watch src/server.ts",
        "start": "node dist/server.js",
        "clean": "rm -rf dist *.tsbuildinfo",
        "lint": "echo \"lint placeholder\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "migrate": "node-pg-migrate up --database-url $PGBOUNCER_URL --migrations-dir migrations"
    },
    "dependencies": {
        "@breeze/shared": "*",
        "fastify": "^4.26.0",
        "@fastify/cookie": "^9.3.0",
        "@fastify/cors": "^9.0.0",
        "@fastify/helmet": "^11.1.0",
        "@fastify/compress": "^7.0.0",
        "pg": "^8.11.3",
        "ioredis": "^5.3.2",
        "jsonwebtoken": "^9.0.2",
        "firebase-admin": "^12.0.0",
        "uuid": "^9.0.1",
        "zod": "^3.22.4",
        "@grpc/grpc-js": "^1.10.0",
        "@grpc/proto-loader": "^0.7.10"
    },
    "devDependencies": {
        "typescript": "^5.4.0",
        "tsx": "^4.7.0",
        "@types/pg": "^8.11.2",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/uuid": "^9.0.8",
        "vitest": "^1.3.0",
        "node-pg-migrate": "^7.0.0"
    }
}